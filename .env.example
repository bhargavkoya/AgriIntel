# App
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/agriintel.db

# Artifact paths (relative to repo root)
ARTIFACTS_DISEASE_PATH=artifacts/disease
ARTIFACTS_YIELD_PATH=artifacts/yield
ARTIFACTS_ADVISOR_PATH=artifacts/advisor

# Module C LLM
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=400

# File uploads
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=10

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
